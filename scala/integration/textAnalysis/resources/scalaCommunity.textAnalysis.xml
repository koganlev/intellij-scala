<idea-plugin package="org.jetbrains.plugins.scala.textAnalysis">
    <dependencies>
        <plugin id="tanvd.grazi"/>
        <module name="scalaCommunity.intelliLang" />
    </dependencies>

    <extensions defaultExtensionNs="com.intellij.spellchecker">
        <bundledDictionaryProvider implementation="org.jetbrains.plugins.scala.textAnalysis.spellchecker.ScalaBundledDictionaryProvider"/>
        <support language="Scala" implementationClass="org.jetbrains.plugins.scala.textAnalysis.spellchecker.ScalaSpellcheckingStrategy"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij.grazie">
        <textExtractor language="Scala" implementationClass="org.jetbrains.plugins.scala.textAnalysis.grazie.ScalaTextExtractor"/>
        <problemFilter language="Scala" implementationClass="org.jetbrains.plugins.scala.textAnalysis.grazie.ScaladocProblemFilter"/>
        <!--Disable rules that are less actual for string literals. Note: same is done for Java. -->
        <problemFilter language="Scala" implementationClass="com.intellij.grazie.text.LiteralProblemFilter"/>
    </extensions>
</idea-plugin>
